repeat
    wait(1)

    --if script.Parent.ClassName == "Player" then
        --a = true
    --end
until a == true

local a = false

local sp=script.Parent

local fatalthreshhold=400

local safethreshhold=65

local lastvelocity=0

while true do
	wait()
	local t=sp
	if t then
		local currentvelocity=(t.Velocity).magnitude
		--print(math.floor(currentvelocity),"Velocity")
		local pain=currentvelocity-safethreshhold
		--print(math.floor(pain),"Pain")
		if pain&gt;0 then
			local damage = pain/(fatalthreshhold-safethreshhold)*100
			t.Health=t.Health-damage
		end
		lastvelocity=currentvelocity
	end
end</string>
          <string name="Name">FallDamage</string>
        </Properties>
      </Item>
